<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ExpenseTracker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:forceDarkAllowed" tools:targetApi="q">true</item>
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorPrimary</item>
        <item name="colorSecondaryVariant">@color/colorPrimary</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->

        <item name="colorBackgroundCards">@color/white</item>
        <item name="colorBorderCards">@color/colorPrimary</item>
        <item name="colorBgResumenRows">@color/bgOnWhite</item>
        <item name="textColorPrimary">@color/colorSurface</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="greyBackground">@color/purple_500</item>
        <item name="onGreyBackground">@color/white</item>
        <item name="filtrarPorBg">@color/white</item>
        <item name="fabBgCircle">@color/white</item>
        <item name="deleteRed">@color/delete_red</item>
        <item name="rowsBorder">@color/rowsBorderLight</item>
        <item name="bgwhitegrey">@color/white</item>
        <item name="whiteBlack">@color/background</item>
        <item name="popupbg">@color/white</item>
        <item name="cardElevationHome">1dp</item>
        <item name="homeTabBackgroundColor">@color/white</item>
        <item name="homeTabTextSelectedColor">?attr/colorInteractivePrimary</item>
        <item name="homeTabIndicatorColor">?attr/colorInteractivePrimary</item>
        <item name="homeTabTextUnselectedColor">#66000000</item>
        <item name="colorInteractivePrimary">@color/interactive_primary_light</item>
        <item name="primary_text">@color/primary_text_light</item>
        <item name="background">@color/app_background_light</item>
        <item name="homeToolbarBackgroundColor">@color/home_header_background_light</item>
        <item name="homeTabsBottomBorderColor">@color/home_tabs_border_light</item>
        <item name="colorInteractiveSecondaryBg">#DFF3EE</item>
        <item name="colorInteractiveSecondaryIcon">?attr/colorInteractivePrimary</item>
        <item name="textPrimary">@color/primary_text_light</item>
        <item name="textSecondary">@color/primary_text_light</item>
        <item name="balanceDividerColor">#D7D7D7</item>
        <item name="contentTabActiveBg">#00806F</item>
        <item name="contentTabInactiveText">#334B46</item>
        <item name="filterChipActiveBg">#E6FAF5</item>
        <item name="filterChipActiveText">#016B5D</item>
        <item name="filterChipActiveIcon">#016B5D</item>
        <item name="filterChipInactiveBorder">#CAC4D0</item>
        <item name="filterChipInactiveText">#49454F</item>
        <item name="filterLabelText">#252525</item>
        <item name="filterChipInactiveBg">#F1F1F1</item>
        <item name="iconsColor">#252525</item>
        <item name="sortDropdownBg">#F9FFFA</item>
        <item name="sortDropdownItemSelectedBg">#B8E9DA</item>
        <item name="sortDropdownText">#334B46</item>
        <item name="sortDropdownTextSelected">#003F36</item>
        <item name="contentCategoryRowBg">#F1F1F1</item>
        <item name="contentCategoryPercentageBg">#C6C6C6</item>
        <item name="contentCategoryPercentageText">#2E2E2E</item>
        <item name="contentCategoryChevronColor">#252525</item>
        <item name="contentCategoryTexts">#252525</item>
        <item name="membersRowTextColor">#6D6D6D</item>
        <item name="fabBackground">#00806F</item>
        <item name="expensePrimaryTextColor">#252525</item>
    </style>

    <style name="ActivityTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">?attr/primary_text</item>
        <item name="android:textStyle">normal</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="CardBodyText">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">?attr/textPrimary</item>
    </style>

    <style name="CardTitleText">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">?attr/textPrimary</item>
    </style>

    <style name="CardNameText">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">?attr/textSecondary</item>
    </style>

    <style name="CardAmountText">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/textSecondary</item>
    </style>

    <style name="CustomChipStyle" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_background_color</item>
        <item name="chipStrokeColor">@color/primary_blue</item>
        <item name="chipSurfaceColor">@color/chip_background_color</item>
        <item name="android:textColor">@color/colorSurface</item>
        <item name="checkedIconTint">@color/primary_blue</item>
    </style>

    <style name="Title" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/colorSurface</item>
        <item name="android:textStyle">bold</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="TotalChart" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/colorSurface</item>
        <item name="android:textStyle">bold</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="Subtitle" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/colorSurface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="Normal" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="NormalBold" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="RowTitle" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">16sp</item>

        <item name="android:textStyle">bold</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="RowTitleDarkGrey" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">16sp</item>

        <item name="android:textStyle">bold</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="Row_Rest" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">16sp</item>

        <item name="android:textStyle">normal</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="ExpenseNames" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">12sp</item>

        <item name="android:textStyle">normal</item>
        <item name="android:typeface">sans</item>
        <item name="textAllCaps">true</item>
        <item name="android:letterSpacing" tools:targetApi="lollipop">0.25</item>
    </style>

    <style name="MyTabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="textAllCaps">false</item>
        <item name="android:textAllCaps">false</item>
    </style>


</resources>