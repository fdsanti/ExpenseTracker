<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="24dp"
    app:cardBackgroundColor="?attr/colorBackgroundCards"
    app:cardCornerRadius="20dp"
    app:cardElevation="?attr/cardElevationHome">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="20dp"
        android:paddingHorizontal="16dp">

        <!-- TOP ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtDebtLabel"
                style="@style/CardBodyText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-" />

            <TextView
                android:id="@+id/txtDebtAmount"
                style="@style/CardBodyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$ 0,00" />
        </LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="?attr/balanceDividerColor" />

        <!-- ACTION -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReviewBalance"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="Revisar balance"
            android:textAllCaps="false"
            android:textColor="?attr/colorInteractivePrimary"
            android:textSize="15sp"
            android:textStyle="normal"
            app:backgroundTint="@android:color/transparent"
            app:icon="@drawable/ic_arrow_forward"
            app:iconGravity="textEnd"
            app:iconPadding="8dp"
            app:iconTint="?attr/colorInteractivePrimary"
            app:rippleColor="?attr/colorInteractivePrimary" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>