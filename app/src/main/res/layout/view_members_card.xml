<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="24dp"
    android:elevation="?attr/cardElevationHome"
    app:cardBackgroundColor="?attr/colorBackgroundCards"
    app:cardCornerRadius="20dp"
    app:cardElevation="?attr/cardElevationHome">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="20dp"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/txtMembersTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Miembros"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtMemberSalary1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="User 1 - $ -"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/txtMemberSalary2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="User 2 - $ -"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnEditMembers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Editar datos" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>