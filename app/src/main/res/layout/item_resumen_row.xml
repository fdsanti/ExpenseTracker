<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="64dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/resumen_row_bg"
    android:clipToOutline="true">

    <!-- Icon Background (Square, flush to edges) -->
    <!-- height=0dp + top/bottom constraints makes it exactly as tall as the row -->
    <View
        android:id="@+id/view_icon_bg"
        android:layout_width="64dp"
        android:layout_height="0dp"
        android:background="@drawable/square_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Icon (Centered in the flush background) -->
    <ImageView
        android:id="@+id/iv_cat_icon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        app:layout_constraintBottom_toBottomOf="@id/view_icon_bg"
        app:layout_constraintEnd_toEndOf="@id/view_icon_bg"
        app:layout_constraintStart_toStartOf="@id/view_icon_bg"
        app:layout_constraintTop_toTopOf="@id/view_icon_bg"
        app:tint="@color/white" />

    <!-- Content Group (Name, Badge, Total) -->
    <!-- We add vertical padding here to make the row taller/breathing -->
    <TextView
        android:id="@+id/tv_cat_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/view_icon_bg"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/Row_Rest"/>

    <TextView
        android:id="@+id/tv_cat_percentage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/badge_background"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:textColor="?attr/editTextColor"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/tv_cat_name"
        app:layout_constraintStart_toEndOf="@id/tv_cat_name"
        app:layout_constraintTop_toTopOf="@id/tv_cat_name" />

    <TextView
        android:id="@+id/tv_cat_total"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/Row_Rest"/>

</androidx.constraintlayout.widget.ConstraintLayout>