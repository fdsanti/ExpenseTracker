<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/expenseBottomSheetBg"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@android:color/darker_gray" />

    <TextView
        android:id="@+id/txtExpenseSheetTitle"
        style="@style/Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="Nuevo gasto" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayout_Who"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="11dp"
            android:layout_weight="1"
            app:hintTextAppearance="@style/ExpenseBottomSheetInputHint">

            <AutoCompleteTextView
                android:id="@+id/dropdown_nombres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rajdhani_medium"
                android:hint="Elegir persona"
                android:inputType="none"
                app:fontFamily="@font/rajdhani_medium" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayout_FechaGasto"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="11dp"
            android:layout_weight="1"
            app:hintTextAppearance="@style/ExpenseBottomSheetInputHint"
            app:startIconDrawable="@drawable/ic_calendar">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editText_FechaGasto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rajdhani_medium"
                android:hint="Fecha de gasto"
                android:inputType="none"
                app:fontFamily="@font/rajdhani_medium" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputLayout_NombreGasto"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:hintTextAppearance="@style/ExpenseBottomSheetInputHint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editText_NombreGasto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/rajdhani_medium"
            android:hint="Nombre del gasto"
            android:inputType="text"
            app:fontFamily="@font/rajdhani_medium" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayout_Gasto"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="14dp"
            android:layout_weight="1"
            app:hintTextAppearance="@style/ExpenseBottomSheetInputHint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editText_Gasto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rajdhani_medium"
                android:hint="Valor $$$"
                android:inputType="numberDecimal"
                app:fontFamily="@font/rajdhani_medium" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/menu_category"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            app:hintTextAppearance="@style/ExpenseBottomSheetInputHint">

            <AutoCompleteTextView
                android:id="@+id/cat_dropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rajdhani_medium"
                android:hint="Categor&#237;a"
                android:inputType="none"
                app:fontFamily="@font/rajdhani_medium" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkIndividualExpense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:buttonTint="?attr/colorInteractivePrimary"
        android:text="Gasto individual"
        android:textColor="?attr/textPrimary"
        android:fontFamily="@font/rajdhani_medium"
        android:textSize="16sp" />

    <FrameLayout
        android:id="@+id/btnCreateExpense"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_debt_closing_button_shadow"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/ripple_tracker_card">

        <TextView
            android:id="@+id/txtCreateExpenseButton"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="@font/rajdhani_semibold"
            android:gravity="center"
            android:includeFontPadding="false"
            android:letterSpacing="0"
            android:text="Crear gasto"
            android:textColor="?attr/debtClosingButtonTextColor"
            android:textSize="16sp"
            android:textStyle="normal"
            app:fontFamily="@font/rajdhani_semibold" />

        <ProgressBar
            android:id="@+id/progressCreateExpense"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="?attr/debtClosingButtonTextColor"
            android:visibility="gone" />
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDeleteExpense"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="Eliminar expense"
        android:fontFamily="@font/rajdhani_medium"
        android:letterSpacing="0"
        android:textAllCaps="false"
        android:textColor="?attr/textPrimary"
        android:textSize="16sp"
        android:textStyle="normal"
        android:visibility="gone"
        app:cornerRadius="12dp"
        app:fontFamily="@font/rajdhani_medium" />

</LinearLayout>
