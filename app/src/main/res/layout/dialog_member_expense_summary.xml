<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_member_expense_summary_dialog"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="24dp"
    android:paddingEnd="16dp"
    android:paddingBottom="24dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="44dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="vertical"
            android:paddingEnd="40dp">

            <TextView
                android:id="@+id/txtMemberDialogName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/rajdhani_semibold"
                app:fontFamily="@font/rajdhani_semibold"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="?attr/expensePrimaryTextColor"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/txtMemberDialogTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:fontFamily="@font/rajdhani_medium"
                app:fontFamily="@font/rajdhani_medium"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="?attr/trackerSummaryLabelColor"
                android:textSize="16dp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnMemberDialogClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|end"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/close"
            android:padding="0dp"
            android:src="@drawable/ic_close_simple"
            app:tint="?attr/trackerSummaryLabelColor" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtGroupLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rajdhani_semibold"
                app:fontFamily="@font/rajdhani_semibold"
                android:includeFontPadding="false"
                android:text="Grupales"
                android:textColor="?attr/trackerSummaryLabelColor"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="6dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/group"
                app:tint="?attr/trackerSummaryLabelColor" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="bottom"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtGroupAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/rajdhani_medium"
                app:fontFamily="@font/rajdhani_medium"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="?attr/expensePrimaryTextColor"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/txtGroupPercentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rajdhani_medium"
                app:fontFamily="@font/rajdhani_medium"
                android:includeFontPadding="false"
                android:textColor="?attr/expensePrimaryTextColor"
                android:textSize="22sp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="?attr/memberExpenseDialogDividerColor" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="19dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtIndividualLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rajdhani_semibold"
                app:fontFamily="@font/rajdhani_semibold"
                android:includeFontPadding="false"
                android:text="Individuales"
                android:textColor="?attr/trackerSummaryLabelColor"
                android:textSize="14dp" />

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="6dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/person"
                app:tint="?attr/trackerSummaryLabelColor" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="bottom"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtIndividualAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/rajdhani_medium"
                app:fontFamily="@font/rajdhani_medium"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="?attr/expensePrimaryTextColor"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/txtIndividualPercentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rajdhani_medium"
                app:fontFamily="@font/rajdhani_medium"
                android:includeFontPadding="false"
                android:textColor="?attr/expensePrimaryTextColor"
                android:textSize="22sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
