<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="12dp">

    <LinearLayout
        android:id="@+id/categoryCardContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_content_category_row"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/categoryRow"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/categoryIconContainer"
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_content_category_icon_block">

                <ImageView
                    android:id="@+id/ivCategoryIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/otros"
                    app:tint="@android:color/white" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/categoryContentContainer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:id="@+id/categoryTextBlock"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvCategoryName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/rajdhani_medium"
                        app:fontFamily="@font/rajdhani_medium"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="Super"
                        android:textColor="?attr/contentCategoryLabelText"
                        android:textSize="14sp"
                        android:textStyle="normal" />

                    <TextView
                        android:id="@+id/tvCategoryAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:fontFamily="@font/rajdhani_semibold"
                        app:fontFamily="@font/rajdhani_semibold"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="$0,00"
                        android:textColor="?attr/contentCategoryAmountText"
                        android:textSize="16sp"
                        android:textStyle="normal" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCategoryPercentage"
                    android:layout_width="wrap_content"
                    android:layout_height="21dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_content_category_percentage"
                    android:fontFamily="@font/rajdhani_medium"
                    app:fontFamily="@font/rajdhani_medium"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:minWidth="31dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="23%"
                    android:textColor="?attr/contentCategoryPercentageText"
                    android:textSize="13sp"
                    android:textStyle="normal" />

                <ImageView
                    android:id="@+id/ivCategoryChevron"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="16dp"
                    android:contentDescription="@null"
                    android:src="@drawable/chevrondown"
                    app:tint="?attr/contentCategoryChevronColor" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/categoryExpensesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
