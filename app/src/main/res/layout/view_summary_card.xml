<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="24dp"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/totalSummaryCard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_tracker_card_shadow"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="20dp"
        android:paddingEnd="8dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/txtTotalLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/rajdhani_medium"
            app:fontFamily="@font/rajdhani_medium"
            android:includeFontPadding="false"
            android:text="Gastos totales"
            android:textColor="?attr/trackerSummaryLabelColor"
            android:textSize="14sp"
            android:letterSpacing="0.018" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/txtTotalAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rajdhani_semibold"
                app:fontFamily="@font/rajdhani_semibold"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="$ 0,00"
                android:textColor="?attr/expensePrimaryTextColor"
                android:textSize="32sp"
                android:letterSpacing="0.015625" />

            <LinearLayout
                android:id="@+id/totalTrendBadge"
                android:layout_width="wrap_content"
                android:layout_height="21dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_content_category_percentage"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/ivTotalTrend"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/trendingup"
                    app:tint="?attr/contentCategoryPercentageText" />

                <TextView
                    android:id="@+id/txtTotalTrend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:fontFamily="@font/rajdhani_medium"
                    app:fontFamily="@font/rajdhani_medium"
                    android:includeFontPadding="false"
                    android:text="3%"
                    android:textColor="?attr/contentCategoryPercentageText"
                    android:textSize="13sp"
                    android:letterSpacing="0.038" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/memberSummaryCards"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_marginTop="24dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/memberCard1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tracker_card_shadow"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/ripple_tracker_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="40dp">

                <TextView
                    android:id="@+id/txtMember1Meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/rajdhani_medium"
                    app:fontFamily="@font/rajdhani_medium"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="-  |  0%"
                    android:textColor="?attr/trackerSummaryLabelColor"
                    android:textSize="14sp"
                    android:letterSpacing="0.018" />

                <TextView
                    android:id="@+id/txtMember1Amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/rajdhani_semibold"
                    app:fontFamily="@font/rajdhani_semibold"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="$ 0,00"
                    android:textColor="?attr/expensePrimaryTextColor"
                    android:textSize="18sp"
                    android:letterSpacing="0.027" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivMember1Expand"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/expand"
                app:tint="?attr/trackerSummaryLabelColor" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/memberCard2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tracker_card_shadow"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/ripple_tracker_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="40dp">

                <TextView
                    android:id="@+id/txtMember2Meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/rajdhani_medium"
                    app:fontFamily="@font/rajdhani_medium"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="-  |  0%"
                    android:textColor="?attr/trackerSummaryLabelColor"
                    android:textSize="14sp"
                    android:letterSpacing="0.018" />

                <TextView
                    android:id="@+id/txtMember2Amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/rajdhani_semibold"
                    app:fontFamily="@font/rajdhani_semibold"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="$ 0,00"
                    android:textColor="?attr/expensePrimaryTextColor"
                    android:textSize="18sp"
                    android:letterSpacing="0.027" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivMember2Expand"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/expand"
                app:tint="?attr/trackerSummaryLabelColor" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
