<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ExpenseTracker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:forceDarkAllowed" tools:targetApi="q">true</item>
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorPrimary</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/colorSurface</item>

        <item name="windowActionBar">false</item>
        <item name="android:colorBackground">@color/gray_bg</item>
        <item name="android:windowBackground">@color/background</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">#000</item>
        <!-- Customize your theme here. -->
        <item name="android:spotShadowAlpha" tools:targetApi="lollipop">0.4</item>

        <item name="colorBackgroundCards">@color/cards_background</item>
        <item name="colorBgResumenRows">@color/cards_background</item>
        <item name="colorBorderCards">@color/cards_border</item>
        <item name="textColorPrimary">@color/white</item>

        <item name="greyBackground">@color/background</item>
        <item name="onGreyBackground">@color/white</item>
        <item name="filtrarPorBg">@color/background</item>
        <item name="fabBgCircle">@color/background</item>
        <item name="deleteRed">@color/delete_red</item>
        <item name="rowsBorder">@color/rowsBorderDark</item>
        <item name="bgwhitegrey">@color/background</item>
        <item name="whiteBlack">@color/white</item>
        <item name="popupbg">@color/darkPopUpBg</item>
        <item name="cardElevationHome">0dp</item>
        <item name="homeTabBackgroundColor">@color/background</item>
        <item name="homeTabTextSelectedColor">?attr/colorInteractivePrimary</item>
        <item name="homeTabIndicatorColor">?attr/colorInteractivePrimary</item>
        <item name="homeTabTextUnselectedColor">#99FFFFFF</item>
        <item name="colorInteractivePrimary">@color/interactive_primary_dark</item>
        <item name="primary_text">@color/primary_text_dark</item>
        <item name="background">@color/app_background_dark</item>
        <item name="homeToolbarBackgroundColor">@color/home_header_background_dark</item>
        <item name="homeTabsBottomBorderColor">@color/home_tabs_border_dark</item>
        <item name="colorInteractiveSecondaryBg">#1E3A36</item>
        <item name="colorInteractiveSecondaryIcon">?attr/colorInteractivePrimary</item>
        <item name="textPrimary">@color/primary_text_dark</item>
        <item name="textSecondary">@color/primary_text_dark</item>
        <item name="balanceDividerColor">#484848</item>
        <item name="contentTabActiveBg">#003C34</item>
        <item name="contentTabInactiveText">#C0C0C0</item>
        <item name="filterChipActiveBg">#1A00CA9F</item>
        <item name="filterChipActiveText">#CDE8E1</item>
        <item name="filterChipActiveIcon">#CDE8E1</item>
        <item name="filterChipInactiveBorder">#4E4E4E</item>
        <item name="filterChipInactiveText">#CAC4D0</item>
        <item name="filterLabelText">#FFFFFF</item>
        <item name="filterChipInactiveBg">#1B1D21</item>
        <item name="iconsColor">#E3E3E3</item>
        <item name="sortDropdownBg">#1B201C</item>
        <item name="sortDropdownItemSelectedBg">#0B312A</item>
        <item name="sortDropdownText">#DFDFDF</item>
        <item name="sortDropdownTextSelected">#CBFFFB</item>
        <item name="contentCategoryRowBg">#1B1D21</item>
        <item name="contentCategoryPercentageBg">#363744</item>
        <item name="contentCategoryPercentageText">#FFFFFF</item>
        <item name="contentCategoryChevronColor">#FFFFFF</item>
        <item name="contentCategoryTexts">#FFFFFF</item>
        <item name="membersRowTextColor">#B6B6B6</item>
        <item name="fabBackground">#004B41</item>
        <item name="expensePrimaryTextColor">#FFFFFF</item>
    </style>

    <style name="ActivityTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">?attr/primary_text</item>
        <item name="android:textStyle">normal</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="CustomChipStyle" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_background_color</item>
        <item name="chipSurfaceColor">@color/chip_background_color</item>
        <item name="android:textColor">@color/chip_text_color</item>
        <item name="checkedIconTint">@color/primary_blue</item>
    </style>

    <style name="ThemeOverlay.App.TabLayout" parent="">
        <item name="colorSurface">@color/background</item>
    </style>


    <style name="Title" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="TotalChart" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="Subtitle" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">normal</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="NormalBold" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="Normal" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">normal</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="RowTitle" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="RowTitleDarkGrey" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/cards_background</item>
        <item name="android:textStyle">bold</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="Row_Rest" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">normal</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="ExpenseNames" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">normal</item>
        <item name="android:typeface">sans</item>
        <item name="textAllCaps">true</item>
        <item name="android:letterSpacing" tools:targetApi="lollipop">0.25</item>
    </style>

    <style name="MyTabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="textAllCaps">false</item>
        <item name="android:textAllCaps">false</item>
    </style>



</resources>